---
import { Code } from 'astro:components';

const covenantCode = `import { declareCovenant, query, mutation } from "@covenant-rpc/core";
import { z } from "zod";

const todoSchema = z.object({ id: z.string(), text: z.string() });

export const covenant = declareCovenant({
  procedures: {
    getTodos: query({
      input: z.null(),
      output: z.array(todoSchema),
    }),
    addTodo: mutation({
      input: z.object({ text: z.string() }),
      output: todoSchema,
    }),
    deleteTodo: mutation({
      input: z.object({ id: z.string() }),
      output: z.null(),
    }),
  },
  channels: {},
});`;

const serverCode = `import { CovenantServer } from "@covenant-rpc/server";
import { emptyServerToSidekick } from "@covenant-rpc/server/interfaces/empty";
import { covenant } from "./covenant";

const todos: { id: string; text: string }[] = [];

export const server = new CovenantServer(covenant, {
  contextGenerator: () => undefined,
  derivation: () => ({}),
  sidekickConnection: emptyServerToSidekick(),
});

server.defineProcedure("getTodos", {
  resources: () => ["todos"],
  procedure: () => todos,
});

server.defineProcedure("addTodo", {
  resources: ({ outputs }) => ["todos", \`todo/\${outputs.id}\`],
  procedure: ({ inputs }) => {
    const todo = { id: crypto.randomUUID(), text: inputs.text };
    todos.push(todo);
    return todo;
  },
});

server.defineProcedure("deleteTodo", {
  resources: ({ inputs }) => ["todos", \`todo/\${inputs.id}\`],
  procedure: ({ inputs, error }) => {
    const i = todos.findIndex(t => t.id === inputs.id);
    if (i === -1) error("Not found", 404);
    todos.splice(i, 1);
    return null;
  },
});

server.assertAllDefined();`;

const clientCode = `import { CovenantClient } from "@covenant-rpc/client";
import { httpClientToServer } from "@covenant-rpc/client/interfaces/http";
import { emptyClientToSidekick } from "@covenant-rpc/client/interfaces/empty";
import { covenant } from "./covenant";

const client = new CovenantClient(covenant, {
  serverConnection: httpClientToServer("/api/covenant", {}),
  sidekickConnection: emptyClientToSidekick(),
});

// Listen auto-refetches whenever addTodo or deleteTodo runs,
// because they all return "todos" in their resources list.
const unsubscribe = client.listen("getTodos", null, (result) => {
  if (result.success) renderTodos(result.data);
});

async function addTodo(text: string) {
  await client.mutate("addTodo", { text });
  // listener refetches automatically — no manual state update needed
}

async function deleteTodo(id: string) {
  await client.mutate("deleteTodo", { id });
}`;
---

<div class="covenant-demo">
  <div class="demo-code">
    <div class="tab-bar" role="tablist">
      <button class="tab-btn active" role="tab" data-target="tab-covenant">covenant.ts</button>
      <button class="tab-btn" role="tab" data-target="tab-server">server.ts</button>
      <button class="tab-btn" role="tab" data-target="tab-client">client.ts</button>
    </div>
    <div class="tab-panels">
      <div id="tab-covenant" class="tab-panel active">
        <Code code={covenantCode} lang="ts" />
      </div>
      <div id="tab-server" class="tab-panel">
        <Code code={serverCode} lang="ts" />
      </div>
      <div id="tab-client" class="tab-panel">
        <Code code={clientCode} lang="ts" />
      </div>
    </div>
  </div>

  <div class="demo-app">
    <div class="demo-header">
      <span class="demo-label">Live Demo</span>
      <span class="demo-hint">Mutations automatically refetch listeners via shared resources</span>
    </div>

    <div class="demo-body">
      <div class="demo-panel server-panel">
        <div class="panel-title">Server</div>
        <div class="server-log" id="server-log">
          <div class="log-idle">Waiting for requests…</div>
        </div>
      </div>

      <div class="demo-panel client-panel">
        <div class="panel-title">Client</div>
        <div class="todo-ui">
          <form class="add-form" id="add-form">
            <input
              id="todo-input"
              type="text"
              placeholder="New todo…"
              autocomplete="off"
            />
            <button type="submit">Add</button>
          </form>
          <ul class="todo-list" id="todo-list">
            <li class="todo-empty">No todos yet</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ── Simulated in-browser "server" ─────────────────────────────────────────

  type Todo = { id: string; text: string };
  const store: Todo[] = [
    { id: "1", text: "Read the overview" },
    { id: "2", text: "Try the quickstart" },
  ];

  function serverGetTodos(): { data: Todo[]; resources: string[] } {
    return { data: [...store], resources: ["todos"] };
  }

  function serverAddTodo(text: string): { data: Todo; resources: string[] } {
    const todo: Todo = { id: crypto.randomUUID(), text };
    store.push(todo);
    return { data: todo, resources: ["todos", `todo/${todo.id}`] };
  }

  function serverDeleteTodo(id: string): { data: null; resources: string[] } {
    const i = store.findIndex((t) => t.id === id);
    if (i !== -1) store.splice(i, 1);
    return { data: null, resources: ["todos", `todo/${id}`] };
  }

  // ── Simulated "CovenantClient" resource listener ──────────────────────────

  let listeners: Map<string, (() => void)[]> = new Map();

  function addListener(resources: string[], fn: () => void) {
    for (const r of resources) {
      if (!listeners.has(r)) listeners.set(r, []);
      listeners.get(r)!.push(fn);
    }
  }

  function invalidate(resources: string[]) {
    const seen = new Set<() => void>();
    for (const r of resources) {
      for (const fn of listeners.get(r) ?? []) {
        if (!seen.has(fn)) { seen.add(fn); fn(); }
      }
    }
  }

  // ── DOM helpers ───────────────────────────────────────────────────────────

  const todoList = document.getElementById("todo-list")!;
  const serverLog = document.getElementById("server-log")!;
  const addForm   = document.getElementById("add-form")! as HTMLFormElement;
  const todoInput = document.getElementById("todo-input")! as HTMLInputElement;

  function renderTodos(todos: Todo[]) {
    todoList.innerHTML = "";
    if (todos.length === 0) {
      todoList.innerHTML = '<li class="todo-empty">No todos yet</li>';
      return;
    }
    for (const todo of todos) {
      const li = document.createElement("li");
      li.className = "todo-item";
      li.innerHTML = `
        <span class="todo-text">${escapeHtml(todo.text)}</span>
        <button class="delete-btn" data-id="${todo.id}" aria-label="Delete">✕</button>
      `;
      todoList.appendChild(li);
    }
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  let logTimeout: ReturnType<typeof setTimeout>;
  function logServer(procedure: string, resources: string[]) {
    clearTimeout(logTimeout);
    serverLog.innerHTML = `
      <div class="log-entry">
        <span class="log-proc">${procedure}()</span>
        <span class="log-arrow">→</span>
        <span class="log-resources">${resources.map(r => `<code>${r}</code>`).join(" ")}</span>
      </div>
      <div class="log-invalidate flash">listeners refetching…</div>
    `;
    logTimeout = setTimeout(() => {
      const inv = serverLog.querySelector(".log-invalidate");
      if (inv) inv.classList.remove("flash");
    }, 600);
  }

  // ── Wire everything together ──────────────────────────────────────────────

  // Initial fetch via listen()
  function fetchTodos() {
    const { data, resources } = serverGetTodos();
    renderTodos(data);
    return resources;
  }

  // Register listener — Covenant's listen() does this after the first fetch
  const initialResources = fetchTodos();
  addListener(initialResources, () => {
    const { data } = serverGetTodos();
    renderTodos(data);
  });

  addForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = todoInput.value.trim();
    if (!text) return;
    todoInput.value = "";

    const { resources } = serverAddTodo(text);
    logServer("addTodo", resources);
    invalidate(resources); // simulates CovenantClient.mutate() triggering listeners
  });

  todoList.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest(".delete-btn") as HTMLElement | null;
    if (!btn) return;
    const id = btn.dataset.id!;
    const { resources } = serverDeleteTodo(id);
    logServer("deleteTodo", resources);
    invalidate(resources);
  });

  // ── Tab switching ─────────────────────────────────────────────────────────

  document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".tab-btn").forEach((b) => b.classList.remove("active"));
      document.querySelectorAll(".tab-panel").forEach((p) => p.classList.remove("active"));
      btn.classList.add("active");
      document.getElementById(btn.dataset.target!)!.classList.add("active");
    });
  });
</script>

<style>
  .covenant-demo {
    margin-block: 2.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--sl-color-bg-sidebar);
  }

  /* ── Code tabs ─────────────────────────────────────────────────── */

  .demo-code {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .tab-bar {
    display: flex;
    gap: 0;
    background: var(--sl-color-bg-nav);
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding: 0 0.75rem;
  }

  .tab-btn {
    padding: 0.6rem 1rem;
    font-size: 0.8rem;
    font-family: var(--sl-font-mono, monospace);
    color: var(--sl-color-gray-2);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    margin-bottom: -1px;
  }

  .tab-btn:hover { color: var(--sl-color-text); }
  .tab-btn.active {
    color: var(--sl-color-text-accent);
    border-bottom-color: var(--sl-color-text-accent);
  }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .tab-panel :global(pre) {
    margin: 0;
    border-radius: 0;
    border: none;
    max-height: 320px;
    overflow-y: auto;
  }

  /* ── Live demo ─────────────────────────────────────────────────── */

  .demo-app {
    padding: 1rem 1.25rem 1.25rem;
  }

  .demo-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .demo-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-text-accent);
  }

  .demo-hint {
    font-size: 0.78rem;
    color: var(--sl-color-gray-3);
  }

  .demo-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
  }

  @media (max-width: 600px) {
    .demo-body { grid-template-columns: 1fr; }
  }

  .demo-panel {
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .panel-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
    padding: 0.45rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-sidebar);
  }

  /* ── Server log ────────────────────────────────────────────────── */

  .server-log {
    padding: 0.75rem;
    min-height: 80px;
    font-size: 0.8rem;
    font-family: var(--sl-font-mono, monospace);
  }

  .log-idle { color: var(--sl-color-gray-4); font-style: italic; }

  .log-entry {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
  }

  .log-proc { color: var(--sl-color-text-accent); font-weight: 600; }
  .log-arrow { color: var(--sl-color-gray-3); }

  .log-resources {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .log-resources code {
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 3px;
    padding: 0.1em 0.35em;
    font-size: 0.75rem;
    color: var(--sl-color-text);
  }

  .log-invalidate {
    color: var(--sl-color-gray-3);
    font-style: italic;
    transition: color 0s;
  }

  .log-invalidate.flash { color: var(--sl-color-text-accent); }

  /* ── Todo UI ───────────────────────────────────────────────────── */

  .todo-ui { padding: 0.75rem; }

  .add-form {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .add-form input {
    flex: 1;
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.35rem;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-text);
    outline: none;
    transition: border-color 0.15s;
  }

  .add-form input:focus { border-color: var(--sl-color-text-accent); }

  .add-form button {
    padding: 0.4rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--sl-color-text-accent);
    color: var(--sl-color-bg);
    border: none;
    border-radius: 0.35rem;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .add-form button:hover { opacity: 0.85; }

  .todo-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .todo-empty {
    font-size: 0.82rem;
    color: var(--sl-color-gray-4);
    font-style: italic;
    padding: 0.25rem 0;
  }

  .todo-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--sl-color-text);
    padding: 0.35rem 0.5rem;
    border-radius: 0.3rem;
    background: var(--sl-color-bg-sidebar);
  }

  .todo-text { flex: 1; word-break: break-word; }

  .delete-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
    line-height: 1;
    padding: 0.15rem 0.3rem;
    border-radius: 0.2rem;
    transition: color 0.15s, background 0.15s;
  }

  .delete-btn:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }
</style>
